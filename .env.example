# MotoShop environment overrides.

# ---- Database ----
POSTGRES_DB=motoshop
POSTGRES_USER=motoshop
POSTGRES_PASSWORD=motoshop

# ---- JWT signing key ----
# Must be at least 32 bytes for HS256. Generate one with:
#   openssl rand -base64 48
APP_JWT_SECRET=secret-key-change-me-please
APP_JWT_EXPIRATION_MINUTES=60

# ---- Initial admin (seeded on first boot, never overwritten) ----
[email protected]
APP_ADMIN_PASSWORD=changeme-admin

# ---- CORS allowed origins (comma-separated) ----
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4300